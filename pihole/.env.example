# IP local de la Raspberry Pi (ej: 192.168.1.100)
RASPBERRY_IP=192.168.1.X

# Contraseña de Pi-hole (la que pusiste al desplegar)
PIHOLE_PASSWORD=tu_contraseña_pihole

# Contraseña de Grafana
GRAFANA_PASSWORD=tu_contraseña_grafana

# Credenciales de ntopng
NTOPNG_USER=admin
NTOPNG_PASSWORD=tu_contraseña_ntopng

# Credenciales del dashboard Flask (SIEM)
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=tu_contraseña_dashboard

# Clave secreta para las sesiones Flask (cadena larga y aleatoria)
FLASK_SECRET_KEY=cambia_esto_por_una_cadena_larga_y_aleatoria

# URL del servidor WireGuard (IP pública o dominio)
WIREGUARD_SERVERURL=tu_ip_publica

# Notificaciones Telegram (opcional)
# Crea un bot con @BotFather y obtén el token
# Obtén tu chat_id arrancando el bot y enviándole /start
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
# Contraseña del panel web de mitmproxy
MITMWEB_PASSWORD=tu_contraseña_mitmweb
# Contraseña de Redis (ntopng)
REDIS_PASSWORD=tu_contraseña_redis
